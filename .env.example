# FleetOS Environment Configuration Template
# Copy this to .env and fill in your values

# === Ollama Configuration ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b
OLLAMA_TIMEOUT=300

# === OpenClaw Configuration ===
OPENCLAW_API_URL=http://localhost:8000
OPENCLAW_TIMEOUT=300

# === Telegram Configuration ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Stripe Integration (Phase 6+) ===
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# === ConvertKit Integration (Phase 6+) ===
CONVERTKIT_API_KEY=your_convertkit_api_key_here
CONVERTKIT_API_SECRET=your_convertkit_api_secret_here

# === Twitter Integration (Phase 6+) ===
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# === Gmail Integration (Phase 6+) ===
GMAIL_SENDER_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# === Memory & Knowledge Store ===
CHROMA_DB_PATH=./company_memory
REDIS_URL=redis://localhost:6379/0

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/fleetos.log

# === Dashboard ===
STREAMLIT_THEME=light
DASHBOARD_PORT=8501

# === Development ===
ENVIRONMENT=development
DEBUG=False
